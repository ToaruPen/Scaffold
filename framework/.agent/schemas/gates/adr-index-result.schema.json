{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scaffold.local/schemas/gates/adr-index-result.schema.json",
  "title": "AdrIndexResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "scope_id",
    "run_id",
    "status",
    "artifact_path",
    "entries",
    "entry_count",
    "mismatch_reasons"
  ],
  "properties": {
    "request_id": {"type": "string", "minLength": 1},
    "scope_id": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "status": {"type": "string", "enum": ["pass", "fail"]},
    "artifact_path": {"type": "string", "minLength": 1},
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "adr_id",
          "title",
          "status",
          "date",
          "file_path",
          "decision_summary",
          "issue_url"
        ],
        "properties": {
          "adr_id": {"type": "string", "minLength": 1},
          "title": {"type": "string", "minLength": 1},
          "status": {"type": "string", "minLength": 1},
          "date": {"type": "string", "minLength": 1, "format": "date"},
          "file_path": {"type": "string", "minLength": 1},
          "decision_summary": {"type": "string", "minLength": 1},
          "issue_url": {"type": "string", "minLength": 1, "format": "uri"},
          "supersedes": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1,
              "pattern": "^ADR-\\d{3,}$",
              "description": "ADR identifier like ADR-001",
              "examples": ["ADR-001", "ADR-123"]
            }
          }
        }
      }
    },
    "entry_count": {"type": "integer", "minimum": 0},
    "mismatch_reasons": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "errors": {
      "type": "array",
      "items": {"$ref": "../common/adapter-error.schema.json"}
    }
  }
}
