{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scaffold.local/schemas/gates/drift-detection-result.schema.json",
  "title": "DriftDetectionResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "scope_id",
    "run_id",
    "status",
    "artifact_path",
    "declared_targets",
    "actual_changes",
    "undeclared_additions",
    "unused_declarations",
    "mismatch_reasons"
  ],
  "properties": {
    "request_id": {"type": "string", "minLength": 1},
    "scope_id": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "status": {"type": "string", "enum": ["pass", "fail"]},
    "artifact_path": {"type": "string", "minLength": 1},
    "declared_targets": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "actual_changes": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "undeclared_additions": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "unused_declarations": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "mismatch_reasons": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "errors": {
      "type": "array",
      "items": {"$ref": "../common/adapter-error.schema.json"}
    }
  }
}
