{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scaffold.local/schemas/gates/estimate-approval-result.schema.json",
  "title": "EstimateApprovalResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "scope_id",
    "run_id",
    "status",
    "artifact_path",
    "issue_id",
    "estimate_ref",
    "assumptions",
    "approval",
    "mismatch_reasons"
  ],
  "properties": {
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "scope_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "fail"
      ]
    },
    "artifact_path": {
      "type": "string",
      "minLength": 1
    },
    "issue_id": {
      "type": "string",
      "minLength": 1
    },
    "estimate_ref": {
      "type": "string",
      "minLength": 1
    },
    "assumptions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "approved_by",
        "approved_at",
        "decision_id"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "approved",
            "rejected",
            "pending"
          ]
        },
        "approved_by": {
          "type": "string",
          "minLength": 1
        },
        "approved_at": {
          "type": "string",
          "minLength": 1
        },
        "decision_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "mismatch_reasons": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "head_sha": {
      "type": "string",
      "minLength": 7
    },
    "base_sha": {
      "type": "string",
      "minLength": 7
    },
    "errors": {
      "type": "array",
      "items": {
        "$ref": "../common/adapter-error.schema.json"
      }
    }
  }
}
