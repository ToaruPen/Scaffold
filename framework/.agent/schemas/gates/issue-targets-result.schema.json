{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scaffold.local/schemas/gates/issue-targets-result.schema.json",
  "title": "IssueTargetsResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "scope_id",
    "run_id",
    "status",
    "artifact_path",
    "issue_id",
    "change_targets",
    "estimated_scope",
    "mismatch_reasons"
  ],
  "properties": {
    "request_id": {"type": "string", "minLength": 1},
    "scope_id": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "status": {"type": "string", "enum": ["pass", "fail"]},
    "artifact_path": {"type": "string", "minLength": 1},
    "issue_id": {"type": "string", "minLength": 1},
    "change_targets": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "estimated_scope": {"type": "string", "minLength": 1},
    "mismatch_reasons": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "errors": {
      "type": "array",
      "items": {"$ref": "../common/adapter-error.schema.json"}
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {"const": "fail"}
        }
      },
      "then": {
        "required": ["mismatch_reasons"],
        "properties": {
          "mismatch_reasons": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    }
  ]
}
