{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scaffold.local/schemas/gates/pr-bot-iteration-result.schema.json",
  "title": "PrBotIterationResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "scope_id",
    "run_id",
    "status",
    "artifact_path",
    "pr_url",
    "iterations",
    "iteration_count",
    "mismatch_reasons"
  ],
  "properties": {
    "request_id": {"type": "string", "minLength": 1},
    "scope_id": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "status": {"type": "string", "enum": ["pass", "fail"]},
    "artifact_path": {"type": "string", "minLength": 1},
    "pr_url": {"type": "string", "minLength": 1},
    "iterations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["bot_name", "feedback_ref", "resolution_status", "resolution_ref"],
        "properties": {
          "bot_name": {"type": "string", "minLength": 1},
          "feedback_ref": {"type": "string", "minLength": 1},
          "resolution_status": {
            "type": "string",
            "enum": ["addressed", "deferred", "rejected"]
          },
          "resolution_ref": {"type": "string", "minLength": 1}
        }
      }
    },
    "iteration_count": {"type": "integer", "minimum": 0},
    "mismatch_reasons": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "errors": {
      "type": "array",
      "items": {"$ref": "../common/adapter-error.schema.json"}
    }
  }
}
