{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scaffold.local/schemas/gates/pr-preconditions-result.schema.json",
  "title": "PrPreconditionsResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "scope_id",
    "run_id",
    "status",
    "artifact_path",
    "scope_lock",
    "review_evidence",
    "head_sha",
    "mismatch_reasons"
  ],
  "properties": {
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "scope_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "fail"
      ]
    },
    "artifact_path": {
      "type": "string",
      "minLength": 1
    },
    "scope_lock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "matched",
        "head_sha"
      ],
      "properties": {
        "matched": {
          "type": "boolean"
        },
        "head_sha": {
          "type": "string",
          "minLength": 7
        },
        "base_sha": {
          "type": "string",
          "minLength": 7
        }
      }
    },
    "review_evidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "review_cycle": {
          "$ref": "#/$defs/ReviewStageEvidence"
        },
        "final_review": {
          "$ref": "#/$defs/ReviewStageEvidence"
        },
        "drift_detection": {
          "$ref": "#/$defs/GateStageEvidence"
        },
        "adr_index": {
          "$ref": "#/$defs/GateStageEvidence"
        }
      }
    },
    "head_sha": {
      "type": "string",
      "minLength": 7
    },
    "base_sha": {
      "type": "string",
      "minLength": 7
    },
    "mismatch_reasons": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "$ref": "../common/adapter-error.schema.json"
      }
    }
  },
  "$defs": {
    "ReviewStageEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "head_sha",
        "artifact_path"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "pass",
            "fail"
          ]
        },
        "head_sha": {
          "type": "string",
          "minLength": 7
        },
        "base_sha": {
          "type": "string",
          "minLength": 7
        },
        "artifact_path": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "GateStageEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "artifact_path"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "pass",
            "fail"
          ]
        },
        "artifact_path": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
