{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scaffold.local/schemas/gates/research-contract-result.schema.json",
  "title": "ResearchContractResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "scope_id",
    "run_id",
    "status",
    "artifact_path",
    "research_ref",
    "created_at",
    "topics",
    "mismatch_reasons"
  ],
  "properties": {
    "request_id": {"type": "string", "minLength": 1},
    "scope_id": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "status": {"type": "string", "enum": ["pass", "fail"]},
    "artifact_path": {"type": "string", "minLength": 1},
    "research_ref": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "topics": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "mismatch_reasons": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "errors": {
      "type": "array",
      "items": {"$ref": "../common/adapter-error.schema.json"}
    }
  }
}
